model Coupon {
     id             String    @id @default(uuid())
     code           String    @unique
     description    String?
     discountType   String // PERCENTAGE | FIXED
     discountValue  Float
     minOrderAmount Float?
     maxDiscount    Float?
     usageLimit     Int?
     usedCount      Int       @default(0)
     isActive       Boolean   @default(true)
     expiresAt      DateTime?

     orders Order[]

     createdAt DateTime @default(now())
     updatedAt DateTime @updatedAt

     @@map("coupons")
}
